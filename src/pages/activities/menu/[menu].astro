---
import BaseLayout from '@/layouts/BaseLayout.astro';
import WaveDivider from '@/components/WaveDivider.astro';
import { getCollection } from 'astro:content';
import {
  ACTIVITY_MENU_LABEL_BY_SLUG,
  ACTIVITY_MENU_SLUGS,
  type ActivityMenuSlug,
} from '@/constants/activity-menus';
import { formatDateYmd } from '@/utils/date';
import { getBlogCategoryListHref } from '@/utils/blog-category-path';
import { getBlogPostHref } from '@/utils/blog-post-path';
import { getCategoryDisplayLabel } from '@/utils/category-label';
import { postMatchesActivityMenuSlug } from '@/utils/activity-menu';
import { getPostListLabel } from '@/utils/post-title';
import { sortBlogPostsByPubDateDesc } from '@/utils/blog-post-sort';

export async function getStaticPaths() {
  return ACTIVITY_MENU_SLUGS.map((menu) => ({ params: { menu } }));
}

const raw = Astro.params.menu;
function isActivityMenuSlug(value: string): value is ActivityMenuSlug {
  return (ACTIVITY_MENU_SLUGS as readonly string[]).includes(value);
}
if (!raw || !isActivityMenuSlug(raw)) {
  return Astro.redirect(getBlogCategoryListHref(import.meta.env.BASE_URL, 'Activities'));
}

const menuSlug = raw as ActivityMenuSlug;
const label = ACTIVITY_MENU_LABEL_BY_SLUG[menuSlug];
const base = import.meta.env.BASE_URL;

const posts = sortBlogPostsByPubDateDesc(
  (await getCollection('blog')).filter((p) => postMatchesActivityMenuSlug(p, menuSlug)),
);

const pageTitle = `${label} の Activities`;
const description = `練習メニューに「${label}」が含まれる Activities 記事一覧です。`;
const activitiesListHref = getBlogCategoryListHref(base, 'Activities');
---

<BaseLayout title={pageTitle} description={description}>
  <header class="page-head">
    <p class="page-head__crumb">
      <a href={base}>トップ</a>
      <span class="page-head__crumb-sep" aria-hidden="true">/</span>
      <a href={activitiesListHref}>{getCategoryDisplayLabel('Activities')}</a>
      <span class="page-head__crumb-sep" aria-hidden="true">/</span>
      <span>{label}</span>
    </p>
    <h1>{pageTitle}</h1>
    <p class="page-head__sub">{posts.length} 件の記事</p>
  </header>

  <WaveDivider variant="squiggle" />

  {
    posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <article class="post-row post-row--activities">
              <h2 class="post-row__title post-row__title--with-date">
                <a href={getBlogPostHref(base, post.slug)}>{getPostListLabel(post.data)}</a>
                <time class="post-row__inline-date" datetime={post.data.pubDate.toISOString()}>
                  {formatDateYmd(post.data.pubDate)}
                </time>
              </h2>
            </article>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">まだ該当する記事がありません。</p>
    )
  }

  <p class="back">
    <a href={activitiesListHref}>← Activities 一覧へ</a>
  </p>
</BaseLayout>

<style>
  .page-head {
    margin-bottom: var(--space-md);
  }

  .page-head h1 {
    margin: 0 0 var(--space-xs);
  }

  .page-head__sub {
    margin: 0;
    color: var(--color-muted);
  }

  .page-head__crumb {
    margin: 0 0 var(--space-sm);
    font-size: 0.88rem;
    color: var(--color-muted);
  }

  .page-head__crumb a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--color-accent) 35%, transparent);
  }

  .page-head__crumb a:hover {
    border-bottom-color: var(--color-accent);
  }

  .page-head__crumb-sep {
    margin-inline: 0.35rem;
    opacity: 0.55;
  }

  .post-list {
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .post-row {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .post-list li:last-child .post-row {
    border-bottom: none;
    padding-bottom: 0;
  }

  .post-row__title {
    margin: 0;
    letter-spacing: 0.1em;
    line-height: 1.45;
  }

  .post-row__title--with-date {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem var(--space-sm);
  }

  .post-row__inline-date {
    flex-shrink: 0;
    margin: 0;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .post-row__title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-row__title a:hover {
    color: var(--color-accent);
  }

  .empty {
    margin: var(--space-md) 0 0;
    color: var(--color-muted);
  }

  .back {
    margin-top: var(--space-xl);
    font-size: 0.95rem;
  }

  .back a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--color-accent) 40%, transparent);
  }

  .back a:hover {
    border-bottom-color: var(--color-accent);
  }
</style>
