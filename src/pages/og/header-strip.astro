---
/**
 * OGP 用: サイトヘッダーのブランド行だけを 1200px 幅で表示。
 * 1200px 幅でスクリーンショットし `src/assets/og/site-header-strip.png` を手動更新する。
 */
import SiteHeaderBrand from '@/components/SiteHeaderBrand.astro';
import '@/styles/global.css';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1200" />
    <title>OG header capture</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Zen+Kaku+Gothic+New:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="og-header-capture" data-og-header-capture>
      <div class="og-header-capture__inner">
        <SiteHeaderBrand />
      </div>
    </div>
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: var(--color-accent);
  }

  .og-header-capture {
    box-sizing: border-box;
    width: 1200px;
    margin: 0;
    padding: 28px 64px;
    background: var(--color-accent);
  }

  .og-header-capture__inner {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .og-header-capture :global(.site-header__brand) {
    flex: 0 1 auto;
    justify-content: center;
    text-align: center;
  }

  .og-header-capture :global(.site-header__title) {
    font-size: 2.625rem;
    text-align: center;
  }

  .og-header-capture :global(.site-header__mark-ring) {
    width: 80px;
    height: 80px;
  }

  .og-header-capture :global(.site-header__mark) {
    width: 68px;
  }
</style>
