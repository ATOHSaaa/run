---
import BaseLayout from '@/layouts/BaseLayout.astro';
import WaveDivider from '@/components/WaveDivider.astro';
import { SITE_TOOLS } from '@/data/tools';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="ツール一覧"
  description="マラソンのペース換算など、ブログで公開しているツールの一覧です。"
>
  <header class="page-head">
    <p class="page-head__crumb">
      <a href={base}>トップ</a>
      <span class="page-head__crumb-sep" aria-hidden="true">/</span>
      <span>ツール</span>
    </p>
    <h1>ツール</h1>
    <p class="page-head__sub">ランニングの目安計算など、便利なページをまとめています。</p>
  </header>

  <WaveDivider variant="squiggle" />

  <ul class="tools-list">
    {
      SITE_TOOLS.map((tool) => (
        <li>
          <a class="tools-card" href={`${base}tools/${tool.slug}/`}>
            <h2 class="tools-card__title">{tool.title}</h2>
            <p class="tools-card__desc">{tool.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .page-head {
    margin-bottom: var(--space-md);
  }

  .page-head__crumb {
    margin: 0 0 var(--space-xs);
    font-size: 0.88rem;
    color: var(--color-muted);
  }

  .page-head__crumb a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }

  .page-head__crumb a:hover {
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .page-head__crumb-sep {
    margin-inline: 0.35rem;
    opacity: 0.65;
  }

  .page-head h1 {
    margin: 0 0 var(--space-xs);
  }

  .page-head__sub {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.55;
  }

  .tools-list {
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .tools-card {
    display: block;
    padding: var(--space-md);
    border: 2px solid var(--color-text);
    border-radius: 0.65rem;
    background: color-mix(in oklab, var(--color-accent-soft) 45%, white);
    text-decoration: none;
    color: inherit;
    box-sizing: border-box;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .tools-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 22px color-mix(in oklab, var(--color-accent) 14%, transparent);
  }

  .tools-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .tools-card__title {
    margin: 0 0 var(--space-xs);
    font-size: clamp(1.05rem, 3vw, 1.2rem);
    line-height: 1.35;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .tools-card:hover .tools-card__title {
    color: var(--color-accent);
  }

  .tools-card__desc {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-muted);
  }
</style>
