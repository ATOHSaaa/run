---
import BaseLayout from '@/layouts/BaseLayout.astro';
import WaveDivider from '@/components/WaveDivider.astro';
import { getCollection } from 'astro:content';
import { formatDateYmd } from '@/utils/date';
import { getPostListLabel } from '@/utils/post-title';
import { getCategoryDisplayLabel, getCategoryPillModifier } from '@/utils/category-label';
import { resolveBlogTags } from '@/utils/blog-tags';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tagSet = new Set(
    posts
      .flatMap((p) => resolveBlogTags(p))
      .filter((t): t is string => typeof t === 'string' && t.trim().length > 0),
  );
  return Array.from(tagSet).map((tag) => ({ params: { tag } }));
}

const raw = Astro.params.tag;
if (!raw) {
  return Astro.redirect(`${import.meta.env.BASE_URL}tags/`);
}

const tag = decodeURIComponent(raw);

const posts = (await getCollection('blog'))
  .filter((p) => resolveBlogTags(p).includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`タグ: ${tag}`} description={`「${tag}」の記事一覧です。`}>
  <header class="page-head">
    <h1>#{tag}</h1>
    <p class="page-head__sub">{posts.length} 件の記事</p>
  </header>

  <WaveDivider variant="wave" />

  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <article class="post-row">
            <h2 class="post-row__title">
              <a href={`${base}blog/${post.slug}/`}>
                {getPostListLabel(post.data)}
              </a>
            </h2>
            <p class="post-row__meta">
              <span
                class={`pill pill--${getCategoryPillModifier(post.data.category)}`}
              >
                {getCategoryDisplayLabel(post.data.category)}
              </span>
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDateYmd(post.data.pubDate)}
              </time>
            </p>
          </article>
        </li>
      ))
    }
  </ul>

  <p class="back">
    <a href={`${base}tags/`}>← タグ一覧へ</a>
  </p>
</BaseLayout>

<style>
  .page-head {
    margin-bottom: var(--space-md);
  }

  .page-head h1 {
    margin: 0 0 var(--space-xs);
  }

  .page-head__sub {
    margin: 0;
    color: var(--color-muted);
  }

  .post-list {
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .post-row {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .post-list > li:last-child .post-row {
    border-bottom: none;
    padding-bottom: 0;
  }

  .post-row__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin: 0.45rem 0 0;
    font-size: 0.88rem;
    color: var(--color-muted);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 0.12rem 0.55rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border: 1px solid color-mix(in oklab, var(--color-accent) 35%, transparent);
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .post-row__title {
    margin: 0;
    letter-spacing: 0.1em;
    line-height: 1.45;
  }

  .post-row__title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-row__title a:hover {
    color: var(--color-accent);
  }

  .back {
    margin-top: var(--space-xl);
    font-size: 0.95rem;
  }

  .back a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--color-accent) 40%, transparent);
  }

  .back a:hover {
    border-bottom-color: var(--color-accent);
  }
</style>
